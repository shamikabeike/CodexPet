{
  "name": "codex-pet",
  "version": "0.1.0",
  "description": "Miao is an open-source cat-shaped Windows companion for local Codex usage and weather.",
  "license": "MIT",
  "author": "CodexPet contributors",
  "homepage": "https://github.com/shamikabeike/CodexPet#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamikabeike/CodexPet.git"
  },
  "bugs": {
    "url": "https://github.com/shamikabeike/CodexPet/issues"
  },
  "keywords": [
    "codex",
    "desktop-pet",
    "electron",
    "usage-monitor",
    "windows"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "package:win": "npm run build && electron-builder --win",
    "package:dir": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "verify": "npm run typecheck && npm test && vite build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "io.github.shamikabeike.codexpet",
    "productName": "Miao",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Miao-${version}-${arch}-${target}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Miao"
    }
  }
}
