{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "electron",
    "src/shared",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
